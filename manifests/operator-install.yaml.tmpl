apiVersion: v1
kind: Namespace
metadata:
  name: {{NAMESPACE}}
---
apiVersion: v1
kind: ServiceAccount
metadata:
  name: data-protection-operator-controller-manager
  namespace: {{NAMESPACE}}
---
apiVersion: rbac.authorization.k8s.io/v1
kind: ClusterRole
metadata:
  name: data-protection-operator-manager-role
rules:
  - apiGroups:
      - dataprotection.archinfra.io
    resources:
      - backupaddons
      - backupjobs
      - backuppolicies
      - backupsources
      - backupstorages
      - notificationendpoints
      - restorejobs
      - retentionpolicies
      - snapshots
    verbs:
      - create
      - delete
      - get
      - list
      - patch
      - update
      - watch
  - apiGroups:
      - dataprotection.archinfra.io
    resources:
      - backupaddons/status
      - backupjobs/status
      - backuppolicies/status
      - backupsources/status
      - backupstorages/status
      - notificationendpoints/status
      - restorejobs/status
      - retentionpolicies/status
      - snapshots/status
    verbs:
      - get
      - patch
      - update
  - apiGroups:
      - batch
    resources:
      - cronjobs
      - jobs
    verbs:
      - create
      - delete
      - get
      - list
      - patch
      - update
      - watch
  - apiGroups:
      - ""
    resources:
      - pods
      - secrets
    verbs:
      - get
      - list
      - watch
  - apiGroups:
      - coordination.k8s.io
    resources:
      - leases
    verbs:
      - create
      - delete
      - get
      - list
      - patch
      - update
      - watch
  - apiGroups:
      - ""
    resources:
      - events
    verbs:
      - create
      - patch
---
apiVersion: rbac.authorization.k8s.io/v1
kind: ClusterRoleBinding
metadata:
  name: data-protection-operator-manager-rolebinding
roleRef:
  apiGroup: rbac.authorization.k8s.io
  kind: ClusterRole
  name: data-protection-operator-manager-role
subjects:
  - kind: ServiceAccount
    name: data-protection-operator-controller-manager
    namespace: {{NAMESPACE}}
---
apiVersion: v1
kind: Service
metadata:
  name: data-protection-notification-gateway
  namespace: {{NAMESPACE}}
  labels:
    app.kubernetes.io/name: data-protection-operator
    app.kubernetes.io/component: notification-gateway
spec:
  selector:
    app.kubernetes.io/name: data-protection-operator
    app.kubernetes.io/component: notification-gateway
  ports:
    - name: http
      port: 8090
      targetPort: 8090
      protocol: TCP
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: data-protection-operator-controller-manager
  namespace: {{NAMESPACE}}
  labels:
    app.kubernetes.io/name: data-protection-operator
    app.kubernetes.io/component: controller-manager
spec:
  replicas: 1
  selector:
    matchLabels:
      app.kubernetes.io/name: data-protection-operator
      app.kubernetes.io/component: controller-manager
  template:
    metadata:
      labels:
        app.kubernetes.io/name: data-protection-operator
        app.kubernetes.io/component: controller-manager
    spec:
      serviceAccountName: data-protection-operator-controller-manager
      containers:
        - name: manager
          image: {{OPERATOR_IMAGE}}
          imagePullPolicy: {{IMAGE_PULL_POLICY}}
          args:
            - --leader-elect
            - --metrics-bind-address=:8080
            - --health-probe-bind-address=:8081
          env:
            - name: DP_DEFAULT_CONTROLLER_IMAGE
              value: {{OPERATOR_IMAGE}}
            - name: DP_DEFAULT_UTILITY_IMAGE
              value: {{UTILITY_IMAGE}}
            - name: DP_DEFAULT_MINIO_HELPER_IMAGE
              value: {{MINIO_HELPER_IMAGE}}
            - name: DP_NOTIFICATION_GATEWAY_URL
              value: http://data-protection-notification-gateway.{{NAMESPACE}}.svc.cluster.local:8090
          ports:
            - name: metrics
              containerPort: 8080
              protocol: TCP
            - name: health
              containerPort: 8081
              protocol: TCP
          livenessProbe:
            httpGet:
              path: /healthz
              port: health
            initialDelaySeconds: 15
            periodSeconds: 20
          readinessProbe:
            httpGet:
              path: /readyz
              port: health
            initialDelaySeconds: 5
            periodSeconds: 10
          resources:
            requests:
              cpu: 100m
              memory: 128Mi
            limits:
              cpu: 500m
              memory: 512Mi
          securityContext:
            allowPrivilegeEscalation: false
            capabilities:
              drop:
                - ALL
            readOnlyRootFilesystem: true
      securityContext:
        runAsNonRoot: true
        seccompProfile:
          type: RuntimeDefault
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: data-protection-notification-gateway
  namespace: {{NAMESPACE}}
  labels:
    app.kubernetes.io/name: data-protection-operator
    app.kubernetes.io/component: notification-gateway
spec:
  replicas: 1
  selector:
    matchLabels:
      app.kubernetes.io/name: data-protection-operator
      app.kubernetes.io/component: notification-gateway
  template:
    metadata:
      labels:
        app.kubernetes.io/name: data-protection-operator
        app.kubernetes.io/component: notification-gateway
    spec:
      serviceAccountName: data-protection-operator-controller-manager
      containers:
        - name: notification-gateway
          image: {{OPERATOR_IMAGE}}
          imagePullPolicy: {{IMAGE_PULL_POLICY}}
          args:
            - notification-gateway
            - --listen-address=:8090
          ports:
            - name: http
              containerPort: 8090
              protocol: TCP
          livenessProbe:
            httpGet:
              path: /healthz
              port: http
            initialDelaySeconds: 5
            periodSeconds: 10
          readinessProbe:
            httpGet:
              path: /healthz
              port: http
            initialDelaySeconds: 3
            periodSeconds: 10
          resources:
            requests:
              cpu: 20m
              memory: 32Mi
            limits:
              cpu: 200m
              memory: 128Mi
          securityContext:
            allowPrivilegeEscalation: false
            capabilities:
              drop:
                - ALL
            readOnlyRootFilesystem: true
      securityContext:
        runAsNonRoot: true
        seccompProfile:
          type: RuntimeDefault
