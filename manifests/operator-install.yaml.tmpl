apiVersion: v1
kind: Namespace
metadata:
  name: {{NAMESPACE}}
---
apiVersion: v1
kind: ServiceAccount
metadata:
  name: data-protection-operator-controller-manager
  namespace: {{NAMESPACE}}
---
apiVersion: rbac.authorization.k8s.io/v1
kind: ClusterRole
metadata:
  name: data-protection-operator-manager-role
rules:
  - apiGroups:
      - dataprotection.archinfra.io
    resources:
      - backuppolicies
      - backupruns
      - backupsources
      - backupstorages
      - restorerequests
      - retentionpolicies
      - snapshots
    verbs:
      - create
      - delete
      - get
      - list
      - patch
      - update
      - watch
  - apiGroups:
      - dataprotection.archinfra.io
    resources:
      - backuppolicies/status
      - backupruns/status
      - backupsources/status
      - backupstorages/status
      - restorerequests/status
      - retentionpolicies/status
      - snapshots/status
    verbs:
      - get
      - patch
      - update
  - apiGroups:
      - batch
    resources:
      - cronjobs
      - jobs
    verbs:
      - create
      - delete
      - get
      - list
      - patch
      - update
      - watch
  - apiGroups:
      - ""
    resources:
      - serviceaccounts
    verbs:
      - create
      - delete
      - get
      - list
      - patch
      - update
      - watch
  - apiGroups:
      - rbac.authorization.k8s.io
    resources:
      - roles
      - rolebindings
    verbs:
      - create
      - delete
      - get
      - list
      - patch
      - update
      - watch
  - apiGroups:
      - coordination.k8s.io
    resources:
      - leases
    verbs:
      - create
      - delete
      - get
      - list
      - patch
      - update
      - watch
  - apiGroups:
      - ""
    resources:
      - events
    verbs:
      - create
      - patch
---
apiVersion: rbac.authorization.k8s.io/v1
kind: ClusterRoleBinding
metadata:
  name: data-protection-operator-manager-rolebinding
roleRef:
  apiGroup: rbac.authorization.k8s.io
  kind: ClusterRole
  name: data-protection-operator-manager-role
subjects:
  - kind: ServiceAccount
    name: data-protection-operator-controller-manager
    namespace: {{NAMESPACE}}
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: data-protection-operator-controller-manager
  namespace: {{NAMESPACE}}
  labels:
    app.kubernetes.io/name: data-protection-operator
    app.kubernetes.io/component: controller-manager
spec:
  replicas: 1
  selector:
    matchLabels:
      app.kubernetes.io/name: data-protection-operator
      app.kubernetes.io/component: controller-manager
  template:
    metadata:
      labels:
        app.kubernetes.io/name: data-protection-operator
        app.kubernetes.io/component: controller-manager
    spec:
      serviceAccountName: data-protection-operator-controller-manager
      containers:
        - name: manager
          image: {{OPERATOR_IMAGE}}
          imagePullPolicy: {{IMAGE_PULL_POLICY}}
          args:
            - --leader-elect
            - --metrics-bind-address=:8080
            - --health-probe-bind-address=:8081
          env:
            - name: DP_DEFAULT_RUNNER_IMAGE
              value: {{PLACEHOLDER_RUNNER_IMAGE}}
            - name: DP_DEFAULT_MYSQL_RUNNER_IMAGE
              value: {{MYSQL_RUNNER_IMAGE}}
            - name: DP_DEFAULT_REDIS_RUNNER_IMAGE
              value: {{REDIS_RUNNER_IMAGE}}
            - name: DP_DEFAULT_MINIO_RUNNER_IMAGE
              value: {{MINIO_RUNNER_IMAGE}}
            - name: DP_DEFAULT_S3_HELPER_IMAGE
              value: {{S3_HELPER_IMAGE}}
            - name: DP_DEFAULT_CONTROLLER_IMAGE
              value: {{OPERATOR_IMAGE}}
          ports:
            - name: metrics
              containerPort: 8080
              protocol: TCP
            - name: health
              containerPort: 8081
              protocol: TCP
          livenessProbe:
            httpGet:
              path: /healthz
              port: health
            initialDelaySeconds: 15
            periodSeconds: 20
          readinessProbe:
            httpGet:
              path: /readyz
              port: health
            initialDelaySeconds: 5
            periodSeconds: 10
          resources:
            requests:
              cpu: 100m
              memory: 128Mi
            limits:
              cpu: 500m
              memory: 512Mi
          securityContext:
            allowPrivilegeEscalation: false
            capabilities:
              drop:
                - ALL
            readOnlyRootFilesystem: true
      securityContext:
        runAsNonRoot: true
        seccompProfile:
          type: RuntimeDefault
